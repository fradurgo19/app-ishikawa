# Frontend
# Set to true only for local development without SharePoint API.
VITE_USE_MOCK_DATA=false
# Local: "npm run dev" (Vite) no sirve /api solo; opciones:
# 1) En otra terminal: npx vercel dev (carga .env con secretos SharePoint). Por defecto el proxy de Vite reenvía /api al puerto 3000.
# 2) O bien: solo URL absoluta del despliegue / vercel dev en otro puerto:
# VITE_API_BASE_URL=https://tu-proyecto.vercel.app
# Si vercel dev escucha en otro host/puerto, ajusta el proxy de Vite:
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3000
VITE_MSAL_CLIENT_ID=
VITE_MSAL_TENANT_ID=
# Optional; defaults to window.location.origin.
VITE_MSAL_REDIRECT_URI=
# Optional; if empty it uses VITE_MSAL_REDIRECT_URI/window.location.origin for popup login.
# Only set this when you explicitly register a different popup redirect URI in Entra ID.
VITE_MSAL_POPUP_REDIRECT_URI=
# Optional comma-separated list. If empty, all authenticated users are coordinators.
VITE_COORDINATOR_EMAILS=

# SharePoint + Azure AD app credentials (server-side on Vercel)
SHAREPOINT_SITE_URL=https://partequipos2.sharepoint.com/sites/servicioposventa
SHAREPOINT_LIST_TITLE=Ishikawa
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Optional: adjust pagination if list is large
SHAREPOINT_PAGE_SIZE=5000

# Optional: set to false to omit $expand=AttachmentFiles on list reads (avoids OData/502 on some tenants; adjuntos nativos no se expanden hasta que se suban de nuevo)
# SHAREPOINT_LIST_ITEMS_EXPAND_ATTACHMENTS=false

# Optional: map SharePoint internal column names if they differ
# Choice fields
SHAREPOINT_FIELD_BRAND=Marca
SHAREPOINT_FIELD_MODEL=Modelo
SHAREPOINT_FIELD_TIPO_EQUIPO=TipoEquipo
SHAREPOINT_FIELD_SECTION=Seccion
SHAREPOINT_FIELD_PROBLEM=Problema
SHAREPOINT_FIELD_ACTIVITY_TYPE=TipoActividad

# Text fields
SHAREPOINT_FIELD_ACTIVITY=Actividad
SHAREPOINT_FIELD_RESOURCE=Recurso
SHAREPOINT_FIELD_TIME=Tiempo

# Optional custom field for author tracking
SHAREPOINT_FIELD_CREATED_BY=

# Optional custom attachment metadata fields.
# Keep empty when using native SharePoint "Attachments" column.
SHAREPOINT_FIELD_ATTACHMENT_NAME=
SHAREPOINT_FIELD_ATTACHMENT_URL=
SHAREPOINT_FIELD_ATTACHMENT_TYPE=
SHAREPOINT_FIELD_ATTACHMENT_SIZE=
